# --- Umgebungsvariablen & Geheimnisse ---
# Enthält Passwörter und DB-Zugangsdaten (NIEMALS hochladen!)
.env
.env.local
.env.production

# --- Abhängigkeiten (Dependencies) ---
# Dieser Ordner wird bei jedem 'npm install' neu generiert
node_modules/
jspm_packages/
web_modules/

# --- Logs ---
# Protokolldateien, falls im Backend Fehler auftreten
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Betriebssystem-Dateien ---
# Temporäre Dateien von macOS und Windows
.DS_Store
Thumbs.db

# --- IDEs und Editoren ---
# Lokale Einstellungen deines Code-Editors
.vscode/
.idea/
*.suo
*.ntvs
*.njsproj
*.sln
